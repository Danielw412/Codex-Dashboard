# Optional. Defaults to `codex` from PATH.
CODEX_BIN=codex

# Optional. Defaults to ~/.codex.
# CODEX_HOME=C:\\Users\\YourName\\.codex

# Polling intervals in milliseconds.
RATE_LIMIT_POLL_MS=60000
ACCOUNT_USAGE_POLL_MS=900000
SESSION_SCAN_MS=120000

# Set to true to run the dashboard with generated sample data.
DEMO_MODE=false

PORT=8787
